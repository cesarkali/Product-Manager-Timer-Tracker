{
  "manifest_version": 3,
  "name": "PMTT Timer",
  "version": "0.1.0",
  "description": "Controle seu timer do PMTT, vincule tickets do Movidesk/Jira e receba sugestões automáticas de categoria no navegador.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PMTT Timer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": ["storage", "alarms", "tabs", "notifications"],
  "host_permissions": [
    "https://bitz.movidesk.com/*",
    "https://bitzsoftwares.atlassian.net/*",
    "https://firestore.googleapis.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://bitz.movidesk.com/*", "https://bitzsoftwares.atlassian.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
