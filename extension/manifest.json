{
  "manifest_version": 3,
  "name": "PMTT Timer",
  "version": "0.2.0",
  "description": "Controle o timer do PMTT no navegador: atalhos, vínculo de tasks e links, e sugestões automáticas de categorias.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PMTT Timer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": ["storage", "alarms", "tabs", "notifications"],
  "host_permissions": [
    "https://firestore.googleapis.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*"
  ]
}
